# ══════════════════════════════════════════════════════════════
# GAS TOWN — Environment Configuration
# ══════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gastown

# ── LLM Provider ─────────────────────────────────────────────
# Options: gemini, openai, anthropic, openrouter
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_API_KEY=your-api-key-here
# Or use provider-specific:
# GEMINI_API_KEY=your-gemini-key
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# ── White-Label Branding ─────────────────────────────────────
# GASTOWN_NAME=My Agent Platform
# GASTOWN_LOGO=/custom-logo.svg

# ── Capacity Limits ──────────────────────────────────────────
# MAX_POLECATS=10
# MAX_MOLECULES=50
# MAX_WORKERS=20
# WISP_TTL=3600
# DAILY_BUDGET=50

# ── Extensions ───────────────────────────────────────────────
# ENABLE_BUILTIN_PLUGINS=true
# CUSTOM_PLUGIN_DIRS=/path/to/plugins

# ── SSE ──────────────────────────────────────────────────────
# SSE_ENABLED=true
# SSE_HEARTBEAT_MS=30000

# ── Bridges (optional) ──────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# WHATSAPP_API_URL=https://...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=pass
