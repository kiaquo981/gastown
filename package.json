{
  "name": "gastown",
  "version": "1.1.0",
  "description": "Gas Town — AI Agent Orchestration Engine. White-label, production-grade AI agent orchestration inspired by Steve Yegge's Gas Town architecture.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "migrate": "psql $DATABASE_URL < migrations/051_meow_engine.sql"
  },
  "keywords": [
    "ai-agents",
    "orchestration",
    "gas-town",
    "meow",
    "molecular-work",
    "agent-framework",
    "llm-orchestration",
    "white-label"
  ],
  "author": "kiaquo981",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kiaquo981/gastown.git"
  }
}
